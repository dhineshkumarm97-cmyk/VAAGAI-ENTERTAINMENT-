rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email_verified == true && 
         request.auth.token.email in ['dhineshkumarm97@gmail.com', 'murugansouthindiadevotional@gmail.com'])
      );
    }

    // Validation for User
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'nickname', 'avatarUrl', 'createdAt', 'updatedAt']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.nickname is string && data.nickname.size() >= 2 && data.nickname.size() <= 20 &&
             data.avatarUrl is string && data.avatarUrl.size() <= 500 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // Validation for Comment
    function isValidComment(data) {
      return data.keys().hasAll(['videoId', 'userId', 'userName', 'text', 'createdAt']) &&
             data.videoId is string && data.videoId.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.userName is string && data.userName.size() <= 100 &&
             data.text is string && data.text.size() <= 2000 &&
             (data.get('likes', 0) is number);
    }

    // Validation for Video
    function isValidVideo(data) {
      return data.keys().hasAll(['title', 'videoUrl', 'uploadedAt']) &&
             data.title is string && data.title.size() <= 200 &&
             data.videoUrl is string && data.videoUrl.size() <= 1000 &&
             data.uploadedAt is timestamp &&
             (data.get('ownerId', '') is string && data.get('ownerId', '').size() <= 128) &&
             (data.get('genre', '') is string) &&
             (data.get('category', '') is string);
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }

    match /videos/{videoId} {
      allow read, list: if true;
      allow create: if isSignedIn() && 
                    (isAdmin() || (incoming().get('ownerId', '') == request.auth.uid)) && 
                    isValidVideo(incoming()) && 
                    incoming().uploadedAt == request.time;
      allow update: if isSignedIn() && 
                    (isAdmin() || (existing().get('ownerId', '') == request.auth.uid)) && 
                    isValidVideo(incoming());
      allow delete: if isAdmin() || (isSignedIn() && existing().get('ownerId', '') == request.auth.uid);
    }

    match /comments/{commentId} {
      // Rule 8: The rule itself must validate the resource being queried
      // For public comments, we allow listing if they are valid.
      allow read, list: if true; 

      allow create: if isSignedIn() && 
                    isValidComment(incoming()) && 
                    incoming().userId == request.auth.uid &&
                    incoming().createdAt == request.time;
      
      allow update: if isSignedIn() && 
                    isValidComment(incoming()) &&
                    (
                      // Author updating text
                      (incoming().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['text', 'updatedAt'])) ||
                      // Anyone liking/disliking (simplified for now, ideally needs a 'likes' subcollection for atomic prevents of multiple likes)
                      (incoming().diff(existing()).affectedKeys().hasOnly(['likes']))
                    );
                    
      allow delete: if isSignedIn() && request.auth.uid == existing().userId;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                    request.auth.uid == userId && 
                    isValidUser(incoming()) && 
                    incoming().uid == userId &&
                    incoming().createdAt == request.time;
      allow update: if isSignedIn() && 
                    request.auth.uid == userId && 
                    isValidUser(incoming()) && 
                    incoming().uid == userId &&
                    incoming().updatedAt == request.time &&
                    incoming().createdAt == existing().createdAt;
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
