{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "nickname": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "nickname", "avatarUrl"]
    },
    "Video": {
      "title": "Video",
      "description": "A video record",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "thumbnail": { "type": "string" },
        "videoUrl": { "type": "string" },
        "category": { "type": "string" },
        "views": { "type": "string" },
        "uploadedAt": { "type": "string", "format": "date-time" },
        "channelName": { "type": "string" },
        "channelAvatar": { "type": "string" },
        "subscribers": { "type": "string" },
        "language": { "type": "string" },
        "year": { "type": "string" },
        "duration": { "type": "string" },
        "rating": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["title", "videoUrl", "ownerId"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Identifies an administrator",
      "type": "object",
      "properties": {
        "email": { "type": "string" }
      },
      "required": ["email"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A user comment on a video",
      "type": "object",
      "properties": {
        "videoId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "likes": { "type": "number" }
      },
      "required": ["videoId", "userId", "userName", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile records"
    },
    "/videos/{videoId}": {
      "schema": "Video",
      "description": "Admin-managed videos"
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "List of administrators"
    },
    "/comments/{commentId}": {
      "schema": "Comment",
      "description": "Global collection of comments for all videos"
    }
  }
}
